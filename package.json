{
  "name": "tailwindcss-scroll-effects",
  "version": "1.0.0",
  "description": "Advanced Tailwind CSS plugin for scroll-based animations and parallax effects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dev:playground": "npx @tailwindcss/cli -i playground/input.css -o playground/output.css --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tailwindcss",
    "plugin",
    "scroll",
    "animation",
    "parallax",
    "reveal"
  ],
  "author": "nidhidipak",
  "license": "MIT",
  "peerDependencies": {
    "tailwindcss": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "tailwindcss": "^4.3.2",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
